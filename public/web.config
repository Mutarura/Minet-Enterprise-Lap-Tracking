<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>

        <!-- Rule 1: API calls — strip /tracker, forward to Node -->
        <rule name="Tracker API Proxy" stopProcessing="true">
          <match url="^tracker/api/(.*)" />
          <action type="Rewrite" url="http://localhost:3000/api/{R:1}" />
        </rule>

        <!-- Rule 2: Socket.IO — strip /tracker, forward to Node -->
        <rule name="Tracker SocketIO Proxy" stopProcessing="true">
          <match url="^tracker/socket.io/(.*)" />
          <action type="Rewrite" url="http://localhost:3000/socket.io/{R:1}" />
        </rule>

        <!-- Rule 3: Everything else — forward to Node root (Node serves SPA) -->
        <rule name="Tracker SPA Proxy" stopProcessing="true">
          <match url="^tracker/(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
        </rule>

      </rules>
    </rewrite>
  </system.webServer>
</configuration>